$C = "../Common.ui";

Group {
  LayoutMode: Top;
  Padding: (Horizontal: 15, Vertical: 10);
  
  Label {
    Style: (
      FontSize: 24,
      TextColor: #ffd700,
      HorizontalAlignment: Center
    );
    Padding: (Bottom: 15);
    Text: "Welcome to Simple Enchantments!";
  }

  Label {
    Style: (
      FontSize: 16,
      TextColor: #ffffff
    );
    Padding: (Bottom: 10);
    Text: "This mod allows you to enhance your gear and weapons using magical scrolls and enchantments.";
  }

  Label {
    Style: (
      FontSize: 18,
      TextColor: #4da6ff
    );
    Padding: (Bottom: 5);
    Text: "1. The Enchanting Table";
  }

  Label {
    Style: (
      FontSize: 14,
      TextColor: #dddddd
    );
    Padding: (Bottom: 15);
    Text: "Craft an Enchanting Table using Copper and Wood. Place it down and interact with it to browse all available Enchantment Scrolls that you can craft. You can also upgrade the table to access higher tier enchantments.";
  }

  Label {
    Style: (
      FontSize: 18,
      TextColor: #4da6ff
    );
    Padding: (Bottom: 5);
    Text: "2. Enchantment Scrolls";
  }

  Label {
    Style: (
      FontSize: 14,
      TextColor: #dddddd
    );
    Padding: (Bottom: 15);
    Text: "Craft scrolls directly at the Enchanting Table using essences, gems, and monster drops. Once crafted, right-click the scroll while holding it to apply the enchantment to a weapon, armor, or tool in your inventory.";
  }

  Label {
    Style: (
      FontSize: 18,
      TextColor: #4da6ff
    );
    Padding: (Bottom: 5);
    Text: "3. Removing Enchantments";
  }

  Label {
    Style: (
      FontSize: 14,
      TextColor: #dddddd
    );
    Padding: (Bottom: 15);
    Text: "Made a mistake? You can craft a Cleansing Scroll to strip off enchantments from an item. If the server enables it, you might even get the scroll back.";
  }

  Label {
    Style: (
      FontSize: 18,
      TextColor: #4da6ff
    );
    Padding: (Bottom: 5);
    Text: "4. Salvaging";
  }

  Label {
    Style: (
      FontSize: 14,
      TextColor: #dddddd
    );
    Padding: (Bottom: 15);
    Text: "If you have an enchanted piece of gear that you no longer need, place it in the Salvaging Station to retrieve valuable dust or essences, effectively destroying the item but refunding some of the enchantment's power.";
  }
}
